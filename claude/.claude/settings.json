{
  "model": "opus[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "case $(uname) in Darwin) osascript -e 'display notification \"Permission approval needed\" with title \"Claude Code - Action Required\"';; Linux) notify-send 'Claude Code - Action Required' 'Permission approval needed';; esac"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "case $(uname) in Darwin) osascript -e 'display notification \"Claude is done and waiting\" with title \"Claude Code\"';; Linux) notify-send 'Claude Code' 'Claude is done and waiting';; esac"
          }
        ]
      },
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "case $(uname) in Darwin) osascript -e 'display notification \"Claude is asking you a question\" with title \"Claude Code\"';; Linux) notify-send 'Claude Code' 'Claude is asking you a question';; esac"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/gsd-check-update.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/gsd-context-monitor.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/gsd-prompt-guard.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "everything-claude-code@everything-claude-code": true,
    "telegram@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": true,
    "claude-mem@thedotmack": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "effortLevel": "xhigh",
  "skipAutoPermissionPrompt": true
}
